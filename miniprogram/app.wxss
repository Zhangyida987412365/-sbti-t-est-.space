/** app.wxss **/
page {
  /* 基础颜色变量 */
  --bg: #f6faf6;
  --panel: #ffffff;
  --text: #1e2a22;
  --muted: #6a786f;
  --line: #dbe8dd;
  --soft: #edf6ef;
  --accent: #6c8d71;
  --accent-strong: #4d6a53;
  --shadow: 0 16px 40px rgba(47, 73, 55, 0.08);
  --radius: 22rpx;

  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
  min-height: 100vh;
}

view, text, image, navigator {
  box-sizing: border-box;
}

.shell {
  padding: 24rpx 16rpx 56rpx;
  width: 100%;
}

.card {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.btn-primary {
  background: var(--accent-strong);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 30rpx rgba(77, 106, 83, 0.18);
  font-weight: 700;
  text-align: center;
  border: none;
  font-size: 32rpx;
}

.btn-secondary {
  background: #fff;
  color: var(--accent-strong);
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  border: 1px solid var(--line);
  font-weight: 700;
  text-align: center;
  font-size: 32rpx;
}
